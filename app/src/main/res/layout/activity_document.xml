<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/sv_main_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@drawable/cr32"
        android:backgroundTint="#f9f7f7">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FAF8F8"
                android:layout_marginBottom="16dp"
                android:elevation="24dp"
                android:orientation="vertical">



                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:background="#FAF8F8"
                    android:paddingVertical="16dp"
                    android:paddingHorizontal="24dp"
                    android:orientation="horizontal">
                    <ImageView
                        android:id="@+id/btn_back"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:src="@android:drawable/star_big_on"
                        android:scaleType="fitXY" />
                    <TextView
                        android:textColor="#040018"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Thông tin bài học" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical" />
                    <ImageView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:src="@android:drawable/star_big_on"
                        android:scaleType="fitXY" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:background="@drawable/d_cr12bd7f8d6"
                android:paddingVertical="8dp"
                android:paddingLeft="93dp"
                android:layout_marginBottom="16dp"
                android:layout_marginHorizontal="24dp"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="8dp"
                    android:src="@android:drawable/star_big_on"
                    android:scaleType="fitXY" />
                <TextView
                    android:textColor="#48A05D"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Lessons Complete" />
                <LinearLayout
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:layout_marginHorizontal="24dp"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/iv_lesson_cover"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginBottom="12dp"
                    android:scaleType="fitXY"
                    tools:src="@android:drawable/star_big_on" /> <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:layout_marginEnd="29dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:orientation="vertical">
                    <TextView
                        android:textColor="#919191"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Bài học" />

                    <TextView
                        android:id="@+id/tv_lesson_title"
                        android:textColor="#000000"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        tools:text="Các loại danh từ" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginEnd="16dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="4dp"
                            android:src="@android:drawable/star_big_on"
                            android:scaleType="fitXY" />
                        <TextView
                            android:id="@+id/tv_lesson_category"
                            android:textColor="#00BD4F"
                            android:textSize="12sp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            tools:text="Loại từ" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="4dp"
                            android:src="@android:drawable/star_big_on"
                            android:scaleType="fitXY" />
                        <TextView
                            android:id="@+id/tv_question_count"
                            android:textColor="#00BD4F"
                            android:textSize="12sp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            tools:text="9 câu hỏi" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

                <TextView
                    android:id="@+id/tv_lesson_description"
                    android:textColor="#373346"
                    android:textSize="14sp"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:layout_weight="1"
                    tools:text="Là một trong các phần ngữ pháp cơ bản nhất mà bất cứ ai học tiếng Anh cũng cần nắm chắc." />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/cr32"
                android:paddingTop="16dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="24dp"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="24dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tab_theory"
                            android:textColor="#55BA5D"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="3dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Lý thuyết" />
                        <LinearLayout
                            android:id="@+id/indicator_theory"
                            android:layout_width="70dp"
                            android:layout_height="2dp"
                            android:background="@drawable/cr22"
                            android:backgroundTint="#00BD4F"
                            android:orientation="vertical" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tab_guide"
                        android:textColor="#B9B9B9"
                        android:textSize="14sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Hướng dẫn" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_example_box"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/s55ba5dsw2cr17bf0fcf0"
                    android:paddingVertical="20dp"
                    android:paddingLeft="24dp"
                    android:paddingRight="48dp"
                    android:layout_marginBottom="24dp"
                    android:layout_marginHorizontal="24dp"
                    android:elevation="2dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_example_context"
                        android:textColor="#252525"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:layout_weight="1"
                        tools:text="Ann đang ở trong xe. Cô ấy đang trên đường đi làm." />
                    <TextView
                        android:id="@+id/tv_example_english"
                        android:textColor="#636363"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        tools:text="Ex: She is driving to work" />
                    <TextView
                        android:id="@+id/tv_example_vietnamese"
                        android:textColor="#000000"
                        android:textSize="12sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        tools:text="Cô ấy đang lái xe đi làm" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_theory_detail"
                        android:textColor="#000000"
                        android:textSize="12sp"
                        android:layout_marginStart="24dp"
                        android:layout_marginEnd="41dp"
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:layout_weight="1"
                        tools:text="Chúng ta dùng thì Simple Present để diễn tả các sự vự việc một cách tổng quát..." />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/tl24tr24lr270ffffff00ffffff"
                        android:paddingTop="20dp"
                        android:orientation="vertical">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#FFFFFF"
                            android:paddingTop="19dp"
                            android:paddingHorizontal="24dp"
                            android:orientation="vertical">

                            <LinearLayout
                                android:id="@+id/btn_take_quiz"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_horizontal"
                                android:background="@drawable/cr50"
                                android:backgroundTint="#55ba5d"
                                android:paddingVertical="12dp"
                                android:layout_marginBottom="33dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:orientation="vertical">
                                <TextView
                                    android:textColor="#FFFFFF"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:layout_height="wrap_content"
                                    android:layout_width="wrap_content"
                                    android:text="Take the quiz" />
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>