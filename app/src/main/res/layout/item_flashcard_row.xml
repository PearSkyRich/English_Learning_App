<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:background="@drawable/cr10"
    android:backgroundTint="#ffffff"
    android:padding="16dp"
    android:layout_marginBottom="16dp"
    android:orientation="horizontal">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/bg_icon_container"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:background="@drawable/cr10"
            android:backgroundTint="#fce5aa"
            android:layout_marginEnd="16dp"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/iv_vocab_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:scaleType="fitXY"
                tools:src="@android:drawable/star_big_on" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_vocab_english"
                android:textColor="#373346"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                tools:text="Sun" />

            <TextView
                android:id="@+id/tv_vocab_vietnamese"
                android:textColor="#696674"
                android:textSize="12sp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                tools:text="Mặt trời" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <ImageView
        android:id="@+id/btn_pronounce"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_lock_silent_mode_off"
        android:clickable="true"
        android:focusable="true"
        android:scaleType="fitXY" />
</LinearLayout>