<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/cr16"
    android:paddingTop="16dp"
    android:layout_marginEnd="16dp"
    android:orientation="vertical">
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="36dp"
        android:layout_marginStart="24dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_topic_title"
            android:textColor="#373346"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            tools:text="500+ Toeic" />

        <TextView
            android:id="@+id/tv_flashcard_count"
            android:textColor="#696674"
            android:textSize="12sp"
            android:layout_marginEnd="24dp"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            tools:text="20 flashcard" />
    </LinearLayout>

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_topic_image"
        app:shapeAppearanceOverlay="@style/cr16"
        android:layout_width="200dp"
        android:layout_height="148dp"
        android:scaleType="fitXY"
        tools:src="@android:drawable/star_big_on" />

</LinearLayout>