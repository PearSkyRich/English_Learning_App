<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/rbybze5wh88t"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/cr32"
        android:backgroundTint="#f8f8f8"
        android:fillViewport="true">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

        <LinearLayout
            android:id="@+id/ra40k1pz7a85"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FAF8F8"
            android:layout_marginBottom="16dp"
            android:elevation="24dp"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/rn883oe16vx"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingVertical="14dp"
                android:paddingHorizontal="23dp"
                android:orientation="horizontal">
                <LinearLayout
                    android:id="@+id/rb2k6x7khq0o"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="1dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/rltk55ux3ifp"
                        android:textColor="#000000"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="9:41"
                        />
                </LinearLayout>
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    />
                <ImageView
                    android:id="@+id/rivw8orwx2xh"
                    android:layout_width="67dp"
                    android:layout_height="11dp"
                    android:src="@android:drawable/star_big_on"
                    android:scaleType="fitXY"
                    />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/rnj7axc2v8ir"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:background="#FAF8F8"
                android:paddingVertical="16dp"
                android:paddingHorizontal="24dp"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/rzwxoal9k95"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:src="@android:drawable/star_big_on"
                    android:scaleType="fitXY"
                    />
                <TextView
                    android:id="@+id/rtbum53yjap"
                    android:textColor="#040018"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Thông tin khóa học"
                    />
                <LinearLayout
                    android:id="@+id/rwt11wq9nyy"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical">
                </LinearLayout>
                <ImageView
                    android:id="@+id/rt65t62xpxvi"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:src="@android:drawable/star_big_on"
                    android:scaleType="fitXY"
                    />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/rkqtsyw54nh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <LinearLayout
                xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:tools="http://schemas.android.com/tools"
                android:id="@+id/layout_course_info_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:layout_marginHorizontal="24dp"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/iv_course_icon"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginBottom="16dp"
                    android:scaleType="fitXY"
                    tools:src="@android:drawable/star_big_on" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:orientation="vertical">

                        <!-- Chữ "Khóa học" thường là cố định nên giữ nguyên android:text -->
                        <TextView
                            android:textColor="#919191"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Khóa học" />

                        <!-- Tên khóa học sẽ lấy từ CSDL -->
                        <TextView
                            android:id="@+id/tv_course_title"
                            android:textColor="#000000"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            tools:text="Danh từ" />
                    </LinearLayout>

                    <!-- Mô tả khóa học sẽ lấy từ CSDL -->
                    <TextView
                        android:id="@+id/tv_course_description"
                        android:textColor="#373346"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        tools:text="Là một trong các phần ngữ pháp cơ bản nhất mà bất cứ ai học tiếng Anh cũng cần nắm chắc" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginEnd="16dp"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginEnd="4dp"
                                android:src="@android:drawable/star_big_on"
                                android:scaleType="fitXY" />

                            <!-- Số bài học sẽ lấy từ CSDL -->
                            <TextView
                                android:id="@+id/tv_lesson_count"
                                android:textColor="#00BD4F"
                                android:textSize="12sp"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                tools:text="16 bài học" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginEnd="4dp"
                                android:src="@android:drawable/star_big_on"
                                android:scaleType="fitXY" />

                            <!-- Thời lượng sẽ lấy từ CSDL -->
                            <TextView
                                android:id="@+id/tv_course_duration"
                                android:textColor="#00BD4F"
                                android:textSize="12sp"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                tools:text="2 giờ" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Thanh Progress Bar tự chế của bạn -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/cr50"
                            android:backgroundTint="#eeedef"
                            android:layout_marginBottom="7dp"
                            android:orientation="vertical">

                            <!-- id này sẽ dùng để tính toán chiều rộng % trong code -->
                            <LinearLayout
                                android:id="@+id/view_progress_fill"
                                android:layout_width="0dp"
                                android:layout_height="8dp"
                                android:background="@drawable/cr19"
                                android:backgroundTint="#27ae60"
                                android:orientation="vertical"
                                tools:layout_width="95dp">
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <!-- Phân số hoàn thành (VD: 3/16) -->
                            <TextView
                                android:id="@+id/tv_progress_fraction"
                                android:textColor="#696674"
                                android:textSize="12sp"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                tools:text="3/16" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_weight="1" />

                            <!-- Phần trăm hoàn thành (VD: 15%) -->
                            <TextView
                                android:id="@+id/tv_progress_percent"
                                android:textColor="#696674"
                                android:textSize="12sp"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                tools:text="15%" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <!-- PHẦN LỘ TRÌNH -->
            <LinearLayout
                android:id="@+id/ra6z4ar4dhft"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/cr32"
                android:paddingTop="16dp"
                android:paddingRight="24dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/r9uhholuysgm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="24dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="24dp"
                        android:orientation="vertical">

                        <TextView
                            android:textColor="#55BA5D"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Lộ trình" />

                        <View
                            android:layout_width="70dp"
                            android:layout_height="2dp"
                            android:background="@drawable/pi_cr22b00bd4f" />
                    </LinearLayout>

                    <TextView
                        android:textColor="#B9B9B9"
                        android:textSize="14sp"
                        android:layout_marginEnd="24dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Mô tả khoá học" />
                </LinearLayout>

                <!-- VÙNG CHỨA DANH SÁCH LEVEL -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:orientation="vertical">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_levels"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_row_lv1"
                        tools:itemCount="4"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
    <!-- tools:listitem="@layout/item_unit_row"
         tools:itemCount="4"              test-->