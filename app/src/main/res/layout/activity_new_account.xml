<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:id="@+id/rw645kwv7ha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@drawable/cr32lr27055ba5d75ce7c4da654"
        android:paddingTop="12dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
<!--Phần đầu-->
            <LinearLayout
                android:id="@+id/rn8o6kjejghc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:layout_marginBottom="63dp"
                android:orientation="vertical">
                <LinearLayout
                    android:id="@+id/rzkracz9xld"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="1dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/riwyd1qodfi9"
                        android:textColor="#FFFFFF"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Learn E"
                        />
                </LinearLayout>
            </LinearLayout>
<!--            Phần giữa-->
            <LinearLayout
                android:id="@+id/rp8adycg0ig"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:background="@drawable/tl32tr32bffffff"
                android:paddingTop="28dp"
                android:orientation="vertical">
                <LinearLayout
                    android:id="@+id/r6y60ne77w09"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:layout_marginBottom="20dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/rr9lzp977b7b"
                        android:textColor="#373346"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Tạo tài khoản"
                        />
                    <TextView
                        android:id="@+id/rrx3qfiee4in"
                        android:textColor="#504D5D"
                        android:textSize="16sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="và bắt đầu học tập ngay hôm nay!"
                        />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/r584pf7ycy9r"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="116dp"
                    android:layout_marginHorizontal="24dp"
                    android:orientation="vertical">
                    <EditText
                        android:inputType="text"
                        android:hint="Email"
                        android:id="@+id/r6qaeiqhoj6v"
                        android:textColor="#696674"
                        android:textSize="14sp"
                        android:layout_marginBottom="20dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/cr50"
                        android:backgroundTint="#faf8f8"
                        android:paddingVertical="16dp"
                        android:paddingHorizontal="24dp"
                        />
                    <LinearLayout
                        android:id="@+id/rs9vro6z9ts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:background="@drawable/cr50"
                        android:backgroundTint="#faf8f8"
                        android:paddingVertical="16dp"
                        android:paddingHorizontal="24dp"
                        android:layout_marginBottom="20dp"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/rnt1q2ne4mfc"
                            android:textColor="#696674"
                            android:textSize="14sp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Mật khẩu"
                            />
                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            />
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/rksc3gcpa0u"
                            app:shapeAppearanceOverlay="@style/cr50"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/star_big_on"
                            android:scaleType="fitXY"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/r0e0xjnpo466o"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:background="@drawable/cr50"
                        android:backgroundTint="#faf8f8"
                        android:paddingVertical="16dp"
                        android:paddingHorizontal="24dp"
                        android:layout_marginBottom="20dp"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/r47cqcj32h9x"
                            android:textColor="#696674"
                            android:textSize="14sp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Nhập lại mật khẩu"
                            />
                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            />
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/reb0lid6kki5"
                            app:shapeAppearanceOverlay="@style/cr50"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/star_big_on"
                            android:scaleType="fitXY"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/rhi5bv9p9emg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/ryypysbxsys"
                            android:textColor="#504D5D"
                            android:textSize="16sp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Liên kết tài khoản"
                            />
                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            />
                        <LinearLayout
                            android:id="@+id/r6bohza3kt4t"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <LinearLayout
                                android:id="@+id/rm8aqdocjar"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/cr8bf0f0f0"
                                android:padding="10dp"
                                android:layout_marginEnd="20dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:orientation="vertical">
                                <com.google.android.material.imageview.ShapeableImageView
                                    android:id="@+id/rj5noxsqnd7a"
                                    app:shapeAppearanceOverlay="@style/cr8"
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:src="@android:drawable/star_big_on"
                                    android:scaleType="fitXY"
                                    />
                            </LinearLayout>
                            <LinearLayout
                                android:id="@+id/rpt3hevsx65o"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/cr8bf0f0f0"
                                android:padding="10dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:orientation="vertical">
                                <com.google.android.material.imageview.ShapeableImageView
                                    android:id="@+id/r63nd30655bq"
                                    app:shapeAppearanceOverlay="@style/cr8"
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:src="@android:drawable/star_big_on"
                                    android:scaleType="fitXY"
                                    />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/rdxmfz43dgem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:background="@drawable/cr16"
                    android:layout_marginBottom="12dp"
                    android:layout_marginHorizontal="24dp"
                    android:orientation="horizontal">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/r0nkafo3u1idg"
                        app:shapeAppearanceOverlay="@style/cr16"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="12dp"
                        android:src="@android:drawable/star_big_on"
                        android:scaleType="fitXY"
                        />
                    <LinearLayout
                        android:id="@+id/rob623npw4ct"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingBottom="1dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/rd3rchz0ba79"
                            android:textColor="#504D5D"
                            android:textSize="16sp"
                            android:layout_height="wrap_content"
                            android:layout_width="match_parent"
                            android:layout_weight="1"
                            android:text="Tôi đã đọc và đồng ý với Chính sách bảo mật của ứng dụng."
                            />
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/r8acll19dpv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:background="@drawable/cr50"
                    android:backgroundTint="#CDCCD1"
                    android:paddingVertical="12dp"
                    android:layout_marginBottom="53dp"
                    android:layout_marginHorizontal="24dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/rd2a6aw534v5"
                        android:textColor="#696674"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Đăng ký"
                        />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
