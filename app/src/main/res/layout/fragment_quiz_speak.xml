<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#faf8f8">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/layout_bottom_action"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="13dp"
                android:text="Nói để chọn phương án"
                android:textColor="#373346"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:layout_marginHorizontal="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/cr16"
                    android:backgroundTint="#55ba5d"
                    android:orientation="vertical"
                    android:paddingLeft="16dp"
                    android:paddingVertical="16dp">
                    <TextView
                        android:id="@+id/tv_question_en"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="How have you been?" />
                    <TextView
                        android:id="@+id/tv_question_vi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        tools:text="Dạo này cậu thế nào?" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/btn_option_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/cr50"
                    android:backgroundTint="#faf8f8"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:paddingVertical="14dp">
                    <TextView
                        android:id="@+id/tv_option_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#373346"
                        android:textSize="16sp"
                        tools:text="I’ve been good. How about you?" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_option_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/cr50"
                    android:backgroundTint="#faf8f8"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:paddingVertical="14dp">
                    <TextView
                        android:id="@+id/tv_option_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#373346"
                        android:textSize="16sp"
                        tools:text="I’ve gone to Europe this summer." />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_option_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/cr50"
                    android:backgroundTint="#faf8f8"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:paddingVertical="14dp">
                    <TextView
                        android:id="@+id/tv_option_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#373346"
                        android:textSize="16sp"
                        tools:text="You need to calm down." />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_option_4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/cr50"
                    android:backgroundTint="#faf8f8"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:paddingVertical="14dp">
                    <TextView
                        android:id="@+id/tv_option_4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#373346"
                        android:textSize="16sp"
                        tools:text="I have a spare room." />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/layout_bottom_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingBottom="32dp"
        android:paddingTop="16dp"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/btn_skip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Không phải lúc này"
                android:textColor="#0084E7"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/btn_microphone"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:clickable="true"
            android:focusable="true"
            android:scaleType="fitXY"
            android:src="@android:drawable/ic_btn_speak_now"
            app:shapeAppearanceOverlay="@style/cr32" />
    </LinearLayout>
</RelativeLayout>