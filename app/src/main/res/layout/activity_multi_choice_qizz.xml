<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:id="@+id/main"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/sv_main_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/cr32"
        android:backgroundTint="#faf8f8"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:background="#FFFFFF"
                    android:paddingVertical="13dp"
                    android:paddingHorizontal="24dp"
                    android:layout_marginBottom="16dp"
                    android:elevation="4dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/btn_close"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="10dp"
                        android:src="@drawable/turnback"
                        android:scaleType="fitXY"
                        android:clickable="true"
                        android:focusable="true"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">



                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="14dp"
                            android:background="@drawable/cr100"
                            android:backgroundTint="#55ba5d"
                            android:orientation="vertical">
                            <View
                                android:id="@+id/view_progress_bar"
                                android:layout_width="105dp"
                                android:layout_height="match_parent"
                                android:background="@drawable/cr100"
                                android:backgroundTint="#55ba5d"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:textColor="#373346"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="74dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Chọn nghĩa đúng của từ" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:layout_marginBottom="118dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_vocabulary"
                            android:textColor="#373346"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            tools:text="Accommodation" />
                        <TextView
                            android:id="@+id/tv_phonetic"
                            android:textColor="#696674"
                            android:textSize="20sp"
                            android:layout_marginTop="4dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            tools:text="/əˌkɑːməˈdeɪʃən/" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/btn_speak_normal"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="16dp"

                            android:src="@drawable/quiz_speaker"

                            android:scaleType="fitXY"
                            android:clickable="true"
                            android:focusable="true"/>
                        <ImageView
                            android:id="@+id/btn_speak_slow"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/quiz_slow"
                            android:scaleType="fitXY"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    android:layout_marginHorizontal="24dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/btn_option_1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:background="@drawable/cr16"
                            android:backgroundTint="#e2f2fd"
                            android:paddingVertical="36dp"
                            android:layout_marginEnd="10dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_option_1"
                                android:textColor="#373346"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                tools:text="Chỗ ở" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btn_option_2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:background="@drawable/cr16"
                            android:backgroundTint="#e2f2fd"
                            android:paddingVertical="36dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_option_2"
                                android:textColor="#373346"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                tools:text="Phòng ngủ" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/btn_option_3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:background="@drawable/cr16"
                            android:backgroundTint="#e2f2fd"
                            android:paddingVertical="36dp"
                            android:layout_marginEnd="10dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_option_3"
                                android:textColor="#373346"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                tools:text="Phòng ăn" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btn_option_4"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:background="@drawable/cr16"
                            android:backgroundTint="#e2f2fd"
                            android:paddingVertical="36dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_option_4"
                                android:textColor="#373346"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                tools:text="Chỗ ăn" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/layout_bottom_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:paddingTop="16dp"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp"
        android:elevation="8dp"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/btn_check_answer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:background="@drawable/cr50"
            android:backgroundTint="#cdccd1"
            android:paddingVertical="12dp"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tv_check_button_text"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Kiểm tra" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>