<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:id="@+id/main"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/sv_test_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/layout_bottom_nav"
        android:background="@drawable/cr32"
        android:backgroundTint="#FAFAFA"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:background="#FAF8F8"
                android:paddingVertical="16dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/turnback"
                    android:scaleType="fitXY" />

                <TextView
                    android:textColor="#040018"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kỳ thi và Chứng chỉ" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:background="@drawable/cr50"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="24dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:src="@android:drawable/ic_menu_search"
                    android:scaleType="fitXY" />

                <EditText
                    android:id="@+id/edt_search_test"
                    android:inputType="text"
                    android:hint="Tìm kiếm bài thi..."
                    android:background="@null"
                    android:textColor="#696674"
                    android:textSize="14sp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:paddingVertical="18dp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_test_kind_tabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:layout_marginHorizontal="24dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_tab_filter" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_tests_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="100dp"
                android:clipToPadding="false"
                tools:listitem="@layout/item_row_lv1"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="center_vertical"
        android:background="@drawable/tl32tr32bffffff"
        android:paddingVertical="20dp"
        android:paddingHorizontal="32dp"
        android:elevation="16dp"
        android:orientation="horizontal">
        <ImageView android:id="@+id/nav_home" android:layout_width="0dp" android:layout_height="24dp" android:layout_weight="1" android:src="@drawable/nav_home" />
        <ImageView android:id="@+id/nav_test" android:layout_width="0dp" android:layout_height="24dp" android:layout_weight="1" android:src="@drawable/nav_test" />
        <ImageView android:id="@+id/nav_flashcard" android:layout_width="0dp" android:layout_height="24dp" android:layout_weight="1" android:src="@drawable/nav_flashcard" />
        <ImageView android:id="@+id/nav_categrory" android:layout_width="0dp" android:layout_height="24dp" android:layout_weight="1" android:src="@drawable/nav_category" />
        <ImageView android:id="@+id/nav_profile" android:layout_width="0dp" android:layout_height="24dp" android:layout_weight="1" android:src="@drawable/profile" />
    </LinearLayout>

</RelativeLayout>